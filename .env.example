# ─── Supabase ────────────────────────────────────────────────
# Found in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────
# Found in: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Found in: dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Generated by running: npx ts-node stripe/setup.ts
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ─── App ─────────────────────────────────────────────────────
# Your production URL (no trailing slash)
# Use https://gigpay.co once your domain is connected
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Email (Resend) ──────────────────────────────────────────
# Sign up free at resend.com — 3,000 emails/month free
# Found in: resend.com → API Keys → Create API Key
# If not set, email notifications are silently skipped
RESEND_API_KEY=re_...
